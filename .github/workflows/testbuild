name: Tangem Private Package Repro

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Debug Build
        run: ./gradlew :domain:models:assemble \
          --stacktrace \
          --info \
          --refresh-dependencies \
          -Dorg.gradle.logging.level=DEBUG
